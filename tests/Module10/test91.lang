int main() {
    Player p1 = Player {
        name: "Alice",
        pos: Point { x: 10 }
    };

    Player p2 = p1;
    p2.name = "Bob";
    p2.pos.x = 99;
    p2.hp = 50;

    int result = p1.pos.x + p1.pos.y + p1.hp + p2.pos.x + p2.pos.y + p2.hp;

    print("TEST 1 OK", p1.name, p1.pos.x, p1.pos.y, p1.hp, p2.name, p2.pos.x, p2.pos.y, p2.hp, result);

    return result;
}

struct Point {
    int x;
    int y = 7;
}

struct Player {
    string name = "NULL";
    Point pos;
    int hp = 100;
}

