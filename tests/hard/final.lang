import "Core.lang";
import <stdlib.h>; // Проверка C-interop

// Класс для управления 4D массивами
class TensorManager {
    System::Data::HyperCube data;
    int id;

    TensorManager(int tensorId) {
        id = tensorId;
        // Инициализация 4D массива: массив массивов массивов массивов
        // Проверка контекстной типизации элементов
        data = [[[[0, 0], [0, 0]], [[0, 0], [0, 0]]]]; 
    }

    // Метод с побочным эффектом на глобальные переменные
    void updateVal(int w, int x, int y, int z, int val) {
        data[w][x][y][z] = val;
    }

    ~TensorManager() {
        print("Tensor ", id, " disposed from memory.");
    }
}

// Функция для проверки семантики значений и shadowing
int ShadowBoss(int x) {
    int x = 100; // Первое перекрытие
    {
        int x = 200; // Второе перекрытие
        {
            int x = 300; // Третье перекрытие
            if (x == 300) {
                int x = 400; // Перекрытие в той же области видимости по очереди
                return x; // Должен вернуть 400
            }
        }
    }
    return x;
}

// Взаимодействие с C и указателями
void NativeCall() {
    uint64 dummyPtr = 0xDEADBEEF; // Тип ptr передается как uint64
    auto message = "C-Interop Test"; // Вывод типа string
    print(message, " with fake ptr: ", dummyPtr);
}

int main() {
    // 1. Изменяем дефолты в другом модуле
    System::SetupConfig();
    System::Data::Config cfg; // Должна иметь depth: 42 и tag: "BOSS_READY"
    print("Config depth: ", cfg.depth);

    // 2. Работа с 4D массивами и встроенными функциями
    TensorManager boss = TensorManager(777);
    boss.updateVal(0, 0, 1, 1, 999);
    
    // Проверка len() для вложенных структур
    print("HyperCube outer len: ", len(boss.data)); // 1
    print("HyperCube inner len: ", len(boss.data[0][0][0])); // 2

    // 3. Динамическое управление массивом (push/pop)
    int[] dynamicList = [];
    push(1, dynamicList);
    push(ShadowBoss(10), dynamicList); // Должно добавить 400
    
    if (len(dynamicList) > 1) {
        print("Shadowing Result: ", dynamicList[1]); // 400
    }

    // 4. Приведения типов и математика
    float64 wide = cast<float64>(pop(dynamicList)); // 400.0
    int8 narrow = cast<int8>(wide); // Сужение обратно в int8
    print("Cast process: ", wide, " -> ", narrow);

    // 5. Проверка Call-by-value для структур
    System::Data::Config cfgCopy = cfg; 
    cfgCopy.depth = 0; 
    if (cfg.depth == 42) {
        print("Value semantics: SUCCESS");
    } else {
        panic("Value semantics: FAILED"); // Аварийное завершение
    }

    NativeCall();

    // 6. Двухпроходный анализ: вызов функции, объявленной ниже
    return FinalCheck(); 
}

int FinalCheck() {
    print("Final Boss defeated.");
    return 0;
}