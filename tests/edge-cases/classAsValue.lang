class CounterVec {
    int[] xs;

    CounterVec(int a, int b) {
        xs = [a, b];
    }

    void set0(int v) {
        xs[0] = v;
    }

    int sum() {
        return xs[0] + xs[1];
    }
}

int main() {
    CounterVec a = CounterVec(1, 2);
    CounterVec b = a;

    b.set0(100);

    print(a.sum(), b.sum());

    return 0;
}