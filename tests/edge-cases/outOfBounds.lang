int safeDivAt(int[] xs, int index, int divisor) {
    if (index >= 0 && index < len(xs) && divisor != 0) {
        return xs[index] / divisor;
    }

    return -1;
}

int main() {
    int[] xs = [10, 20];

    print(safeDivAt(xs, 5, 0));
    print(safeDivAt(xs, 1, 0));
    print(safeDivAt(xs, 1, 2));

    int bad = xs[-1];
    print(bad);

    return 0;
}