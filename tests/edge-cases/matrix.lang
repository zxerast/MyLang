int[2][2] multiply(int[3][2] a, int[2][3] b) {
    int[2][2] c = [[0, 0], [0, 0]];

    int i = 0;
    while (i < 2) {
        int j = 0;
        while (j < 2) {
            int k = 0;
            int sum = 0;

            while (k < 3) {
                sum = sum + a[i][k] * b[k][j];
                k = k + 1;
            }

            c[i][j] = sum;
            j++;
        }
        i++;
    }

    return c;
}

int main() {
    int[3][2] a = [
        [1, 2, 3], 
        [4, 5, 6]
    ];
    int[2][3] b = [
        [7, 8], 
        [9, 10], 
        [11, 12]
    ];

    int[2][2] c = multiply(a, b);

    print(c[0][0], c[0][1], c[1][0], c[1][1]);
    return 0;
}