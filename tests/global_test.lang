// Тест глобальных переменных (проблема #10)
int counter = 42;
string greeting = "hello";
int[] buffer = [1, 2, 3];

int bump() {
    counter = counter + 1;
    return counter;
}

int main() {
    print(counter);                 // 42
    print(greeting);                // hello
    print(buffer[0] + buffer[2]);   // 4
    print(len(buffer));             // 3
    counter++;
    print(counter);                 // 44
    print(bump());                  // 45
    print(counter);                 // 45
    push(buffer, 99);
    print(buffer[3]);               // 99
    print(len(buffer));             // 4
    return 0;
}
