int main(){
    int[] arr = [8, 3, 1, 54, 72, 12, 1, 6, 3];
    int i = 1;
    int j = 0;

    while(i < len(arr)){
        j = 0;
        while(j < len(arr) - i){
            if(arr[j] > arr[j + 1]){
                int tmp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
            j++;
        }
        i++;
    }

    print(arr);
    return 0;
}
