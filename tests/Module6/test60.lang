int main() {
    Math::Cell[3] cells = [
        Math::makeCell(2),
        Math::makeCell(3),
        Math::makeCell(4)
    ];

    auto a = cells[0].value + cells[1].value * cells[2].value;  //  14
    auto b = (cells[0].value + cells[1].value) * cells[2].value;    //  20
    auto c = cells[0].value ^ cells[1].value ^ 2;   //  512

    cells[0].value++;   //  3
    cells[1].value--;   //  2

    bool check1 = a < b;    //  true
    bool check2 = c > 100;  //  true
    bool check3 = !(cells[0].value == cells[1].value);  //  true

    int result = a + b + cast<int>(check1) + cast<int>(check2) + cast<int>(check3);
    //  14 + 20 + 1 + 1 + 1

    {
        int result = 1000;
        result = result + cells[0].value + cells[1].value + cells[2].value;
        print("TEST 10 INNER", result);
    }

    print("TEST 10 OK", a, b, c, check1, check2, check3, result);

    return result;
}

namespace Math {
    struct Cell {
        Small value;
    }

    Cell makeCell(Small x) {
        return Cell { value: x };
    }
}

type Small = int8;


