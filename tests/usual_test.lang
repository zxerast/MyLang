import <stdio.h>;

struct Pair{
    int num;
    string name;
}

class MyClass {
    Pair p = Pair{};
    Pair[] arr;

    void Add(int x, string y){
        p.num = x;
        p.name = y;
        push(arr, p);
        p = Pair{};
    };

    int GetPos(int i){
        return(arr[i].num);
    }

    void Print(){
        int i = 0;
        while(i < len(arr)){
            auto curr = arr[i];
            print(curr.num, "->", curr.name);
            i++;
        };
    };
}

int main(){
    MyClass obj = new MyClass();

    obj.Add(1, "Me");
    obj.Add(2, "You");
