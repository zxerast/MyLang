int main() {
    int x = 0;
    int result = classify(x);

    print("TEST 2 OK", result);

    return result;
}

int classify(int x) {
    if (x < 0) {
        return -1;
    } else if (x == 0) {
        return 0;
    } else if (x < 10) {
        return 1;
    } else {
        return 2;
    }
}

